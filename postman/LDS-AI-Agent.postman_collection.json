{
  "info": {
    "name": "LDS External AI Agent",
    "description": "Curated collection for the LDS Chatbot and related APIs. Import this single JSON only. Then: 1) Edit collection → Variables → set username and password (AI agent's Admin Portal credentials, not LDS) 2) Run **1. Retrieve Access Token** 3) Call any API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{access_token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://ronald-test.cite.hku.hk" },
    { "key": "username", "value": "" },
    { "key": "password", "value": "" },
    { "key": "client_id", "value": "" },
    { "key": "client_secret", "value": "" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "conversation_id", "value": "" },
    { "key": "auth_code", "value": "" },
    { "key": "redirect_uri", "value": "http://localhost:5173/callback" },
    { "key": "scope", "value": "chatbot" }
  ],
  "item": [
    {
      "name": "0 - Auth",
      "description": "Run **1. Retrieve Access Token** with Admin Portal username and password (not LDS) to get and save access_token.",
      "item": [
        {
          "name": "1. Retrieve Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.access_token) pm.collectionVariables.set('access_token', body.access_token);",
                  "    if (body.refresh_token) pm.collectionVariables.set('refresh_token', body.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{username}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" }
              ]
            },
            "url": "{{base_url}}/api/auth/token",
            "description": "Get access token. Body: x-www-form-urlencoded with username and password (Admin Portal / LDS Chatbot user). Saves access_token and refresh_token to collection variables."
          }
        },
        {
          "name": "Get JWT Token (OAuth2 authorization code)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "authorization_code", "type": "text" },
                { "key": "code", "value": "{{auth_code}}", "type": "text" },
                { "key": "redirect_uri", "value": "{{redirect_uri}}", "type": "text" },
                { "key": "client_id", "value": "{{client_id}}", "type": "text" },
                { "key": "client_secret", "value": "{{client_secret}}", "type": "text" },
                { "key": "scope", "value": "{{scope}}", "type": "text" },
                { "key": "username", "value": "{{username}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" }
              ]
            },
            "url": "{{base_url}}/api/auth/token",
            "description": "Exchange OAuth2 authorization code for JWT. Body includes grant_type, code, redirect_uri, client_id, client_secret, scope, username, password. Set auth_code after redirect."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.access_token) pm.collectionVariables.set('access_token', body.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "refresh_token", "value": "{{refresh_token}}", "type": "text" }
              ]
            },
            "url": "{{base_url}}/api/auth/refresh",
            "description": "Refresh access token. Body: x-www-form-urlencoded with refresh_token. Saves new access_token to collection variables."
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me",
            "description": "Returns current user info. Requires valid access_token."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/logout",
            "description": "Logout and invalidate session."
          }
        }
      ]
    },
    {
      "name": "1 - System",
      "item": [
        {
          "name": "Health Check (Root)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{base_url}}/",
            "description": "Simple health check."
          }
        },
        {
          "name": "Health Check (API)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{base_url}}/api/health",
            "description": "Detailed API health check."
          }
        }
      ]
    },
    {
      "name": "2 - Core",
      "description": "Core chatbot and learning-design endpoints. LDS 建議優先使用 General Bot、ILO Bot。Require access_token (run 1. Retrieve Access Token first).",
      "item": [
        {
          "name": "General Bot (LDS)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"How do I write good learning outcomes?\",\n  \"courseInfo\": {},\n  \"referrer_pathname\": \"\",\n  \"form_state\": null\n}\n"
            },
            "url": "{{base_url}}/api/general_bot",
            "description": "LDS-compatible 一般對話。必填: message, courseInfo。可選: referrer_pathname, form_state, disciplinaryPractices, pedagogicalApproaches, intendedLearningOutcomes, lessons。回傳: chat_message_reply, actions."
          }
        },
        {
          "name": "ILO Bot (LDS)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseInfo\": {},\n  \"referrer_pathname\": \"\",\n  \"form_state\": null\n}\n"
            },
            "url": "{{base_url}}/api/ilo_bot",
            "description": "LDS-compatible 生成 ILO 建議。必填: courseInfo。可選: referrer_pathname, form_state, 學習設計陣列。回傳: chat_message_reply, actions (e.g. show_suggestion)."
          }
        },
        {
          "name": "Chat",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"How do I write good learning outcomes?\",\n  \"conversation_id\": \"\"\n}\n"
            },
            "url": "{{base_url}}/api/chat",
            "description": "General chat interface. Optional conversation_id for continuity."
          }
        },
        {
          "name": "Generate ILOs",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic\": \"Introduction to Python\",\n  \"level\": \"undergraduate\",\n  \"language\": \"en_US\"\n}\n"
            },
            "url": "{{base_url}}/api/generate_ilos",
            "description": "Generate Intended Learning Outcomes. language: en_US or zh_HK."
          }
        },
        {
          "name": "Suggest Disciplinary Practices",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic\": \"Data Science\",\n  \"context\": \"First year course\"\n}\n"
            },
            "url": "{{base_url}}/api/suggest_dp",
            "description": "Suggest Disciplinary Practices for a topic."
          }
        },
        {
          "name": "Analyze Document",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{base_url}}/api/analyze-document",
            "description": "Analyze teaching document (PDF, DOCX, TXT). Set file in form-data."
          }
        },
        {
          "name": "Extract Course Info",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{base_url}}/api/extract-course-info",
            "description": "Extract course info from uploaded docs."
          }
        },
        {
          "name": "Save Conversation",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"messages\": []\n}\n"
            },
            "url": "{{base_url}}/api/save-conversation",
            "description": "Save conversation history. Set conversation_id and messages in body."
          }
        }
      ]
    }
  ]
}
